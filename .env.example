# Database
DATABASE_URL=sqlite:///./outreach.db
# For PostgreSQL: postgresql+asyncpg://user:password@localhost/outreach

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# LLM Configuration
# Provider: "fireworks" (default, uses Kimi K2.5 Turbo) or "openai"
LLM_PROVIDER=fireworks

# Fireworks AI Configuration (Primary when LLM_PROVIDER=fireworks)
FIREWORKS_API_KEY=your_fireworks_api_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/routers/kimi-k2p5-turbo

# OpenAI Configuration (Fallback when using Fireworks, or Primary when LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# Legacy setting (deprecated, use provider-specific settings above)
# LLM_MODEL=gpt-4

# Application Settings
DRY_RUN_DEFAULT=true
LOG_LEVEL=INFO

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

# Rate Limiting
MAX_SEND_RATE_PER_MINUTE=30
MAX_CONCURRENT_SENDS=3
